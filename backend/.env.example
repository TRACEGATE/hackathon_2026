# 이 파일은 "템플릿"입니다 (git 커밋 대상). 실제 키는 여기 넣지 말고 .env 에 넣으세요.
# 복사: cp .env.example .env  → .env 안의 값만 실제 키로 교체 (.env 는 .gitignore 됨)

# Claude API 키 (필수) — 콘솔에서 발급: https://console.anthropic.com/
# 백엔드 경유로만 사용되며, 절대 프론트엔드/클라이언트로 노출하지 않습니다.
ANTHROPIC_API_KEY=sk-ant-...

# 사용할 모델 (선택). 기본값: claude-opus-4-8
VEILNOTE_MODEL=claude-opus-4-8

# effort: low | medium | high | xhigh | max (선택). 기본값: medium
VEILNOTE_EFFORT=medium

# 서버 포트 (선택). 기본값: 3000
PORT=3000
